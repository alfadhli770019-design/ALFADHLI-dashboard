import streamlit as st
import pandas as pd
import plotly.express as px

st.set_page_config(page_title="داشبورد المبيعات", layout="wide")
st.title("📊 أداء الفروع اليومي (بالجرام)")

try:
    # قراءة الملف الجديد
    df = pd.read_csv('data.csv')
    
    # عرض الأرقام السريعة
    total_sales = df['الصافي_بالجرام'].sum()
    st.metric("إجمالي جرامات اليوم", f"{total_sales:.2f} جرام")

    # رسم بياني تفاعلي
    fig = px.bar(df, x='الفرع', y=['الصافي_بالجرام', 'الهدف_اليومي'],
                 title="المبيعات مقابل الهدف",
                 barmode='group',
                 color_discrete_sequence=['#FFD700', '#C0C0C0'])
    
    st.plotly_chart(fig, use_container_width=True)
    
    # عرض الجدول للتأكد
    st.write("### تفاصيل البيانات", df)

except Exception as e:
    st.error(f"خطأ: تأكد من رفع ملف data.csv بشكل صحيح. التفاصيل: {e}")
